pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scmGit(
                    branches: [[name: '*/main']],
                    userRemoteConfigs: [[url: 'https://github.com/manojgk0210-hue/Java-calculator-webapp-Devops.git']]
                )
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean deploy'
            }
        }

        stage('Get Latest Artifact') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-creds',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASSWORD'
                )]) {
                    script {

                        env.ARTIFACT_URL = sh(
                            script: '''
                            curl -s -u "$NEXUS_USER:$NEXUS_PASSWORD" \
                            "http://34.207.72.149:8081/service/rest/v1/search/assets?repository=calculator-web-application-Snap&maven.groupId=com.example&maven.artifactId=calculator-web-application&maven.baseVersion=0.0.1-SNAPSHOT" \
                            | jq -r '
                                .items
                                | sort_by(.lastModified)
                                | reverse
                                | map(select(.path | endswith(".war")))
                                | .[0].downloadUrl
                            '
                            ''',
                            returnStdout: true
                        ).trim()

                        echo "Latest WAR URL = ${env.ARTIFACT_URL}"

                        if (!env.ARTIFACT_URL || env.ARTIFACT_URL == "null") {
                            error("Latest WAR URL not found.")
                        }
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-creds',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASSWORD'
                )]) {

                    sh """
                    ansible-playbook \
                    -i ansible/inventory \
                    ansible/deploy.yml \
                    -e nexus_url='${env.ARTIFACT_URL}' \
                    -e nexus_user='$NEXUS_USER' \
                    -e nexus_password='$NEXUS_PASSWORD'
                    """
                }
            }
        }
    }
}
